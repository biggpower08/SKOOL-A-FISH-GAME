{
  "name": "skool-a-fish-game",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:itch": "tsc --noEmit && vite build --mode itch --base ./",
    "pack:itch": "npm run build:itch && node scripts/package-itch.mjs",
    "verify:itch": "node scripts/verify-itch.mjs",
    "preview:itch": "npm run build:itch && vite preview --host 127.0.0.1",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
